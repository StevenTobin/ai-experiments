  "panels": [
    {
      "title": "Pipeline Stage Durations",
      "description": "How long each stage of the release pipeline takes per release.\n\nThe release pipeline has two main stages:\n\n1. **Accumulation** (first PR merge to release tag): How long changes batch up before a release is cut. Driven by the release cadence.\n\n2. **Downstream propagation** (release tag to downstream branch creation): How long until the downstream team creates the corresponding rhoai-x.y branch. Reflects cross-team coordination speed.",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "title": "Accumulation (first PR merge to release tag)",
      "description": "Days from the earliest PR merge in a release to the release tag date. This measures how long changes sit in the integration branch before being shipped.\n\nShorter accumulation = faster time-to-market for individual changes. Longer accumulation = larger batch sizes with more risk.",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 21
              },
              {
                "color": "orange",
                "value": 30
              },
              {
                "color": "red",
                "value": 42
              }
            ]
          }
        }
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "dora_pipeline_accumulation_days",
          "legendFormat": "{{release}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "instant": true
        }
      ]
    },
    {
      "title": "Downstream Propagation (tag to downstream branch)",
