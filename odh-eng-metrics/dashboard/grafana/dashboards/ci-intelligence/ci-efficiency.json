        ]
      },
      "options": {
        "xField": "week",
        "stacking": "none",
        "barWidth": 0.7,
        "showValue": "never"
      },
      "targets": [
        {
          "expr": "odh_eng_ci_weekly_cycles",
          "legendFormat": "Total cycles",
          "refId": "A",
