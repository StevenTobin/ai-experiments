            "renameByName": { "Value #A": "Total cycles", "Value #B": "Failures" }
          }
        },
        {
          "id": "sortBy",
          "options": { "sort": [{ "field": "week" }] }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "title": "Weekly Failures by Test Type",
      "description": "Job-level failures broken down by test type per week.\n\nIdentifies which tests are the biggest contributors to CI failures and whether specific test types are improving or regressing.\n\nCategories: e2e (ODH e2e), rhoai-e2e, hypershift-e2e, images (all image/mirror jobs), bundles (all bundle/index jobs).",
      "type": "barchart",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 46 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rhoai-e2e" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "e2e" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "hypershift-e2e" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          },
          {
            "matcher": { "id": "byName", "options": "images" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          },
          {
            "matcher": { "id": "byName", "options": "bundles" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }]
          }
        ]
      },
      "options": {
        "xField": "week",
        "stacking": "normal",
        "barWidth": 0.7,
        "showValue": "never",
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (week) (odh_eng_ci_weekly_job_failures{exported_job=~\"opendatahub-operator-e2e|operator-e2e\"})",
          "legendFormat": "e2e",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true,
          "format": "table"
        },
        {
          "expr": "sum by (week) (odh_eng_ci_weekly_job_failures{exported_job=\"opendatahub-operator-rhoai-e2e\"})",
          "legendFormat": "rhoai-e2e",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true,
          "format": "table"
        },
        {
          "expr": "sum by (week) (odh_eng_ci_weekly_job_failures{exported_job=\"opendatahub-operator-e2e-hypershift\"})",
          "legendFormat": "hypershift-e2e",
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true,
          "format": "table"
        },
        {
          "expr": "sum by (week) (odh_eng_ci_weekly_job_failures{exported_job=~\"images|incubation-images|image-mirror|.*pr-image-mirror\"})",
          "legendFormat": "images",
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true,
          "format": "table"
        },
        {
          "expr": "sum by (week) (odh_eng_ci_weekly_job_failures{exported_job=~\"ci-bundle.*|ci-index\"})",
          "legendFormat": "bundles",
          "refId": "E",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "week", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #A": "e2e",
              "Value #B": "rhoai-e2e",
              "Value #C": "hypershift-e2e",
              "Value #D": "images",
              "Value #E": "bundles"
            }
          }
        },
        {
          "id": "sortBy",
          "options": { "sort": [{ "field": "week" }] }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "title": "E2E Test Failures",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 55 },
      "collapsed": false
