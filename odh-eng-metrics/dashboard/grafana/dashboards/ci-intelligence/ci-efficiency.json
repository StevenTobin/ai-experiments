{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Overview",
      "url": "/d/odh-eng-overview",
      "type": "link"
    }
  ],
  "panels": [
    {
      "title": "CI Efficiency Summary",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "First-Pass Success Rate",
      "description": "Percentage of PRs where the first test cycle (all CI jobs) passed without retesting.\n\nHigher is better. A low rate indicates flaky tests or infrastructure instability forcing developers to retest.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.7 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "odh_eng_ci_first_pass_success_rate{period=\"$period\"}",
          "legendFormat": "First-pass",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true
        }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "title": "Retest Tax",
      "description": "Average number of test cycles per PR. An ideal value is 1.0 (every PR passes on the first try).\n\nEach cycle triggers all CI jobs in parallel. Values above 2.0 indicate significant CI instability or test flakiness.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.5 },
              { "color": "orange", "value": 2.5 },
              { "color": "red", "value": 4 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "odh_eng_ci_retest_tax{period=\"$period\"}",
          "legendFormat": "cycles/PR",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true
        }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "title": "Cycle Failure Rate",
      "description": "Percentage of test cycles that failed (any job in the cycle had a failure).\n\nThis includes infrastructure failures, flaky tests, and genuine regressions. Compare with the DORA Change Failure Rate which only counts production-impacting failures.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.15 },
              { "color": "orange", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "odh_eng_ci_cycle_failure_rate{period=\"$period\"}",
          "legendFormat": "Failure rate",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true
        }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "title": "Cycle Duration (p50 / p90)",
      "description": "Median and 90th-percentile test cycle wall-clock duration in minutes.\n\nMeasures how long developers wait for CI feedback per cycle (max of parallel jobs). Long durations compound with retest tax.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 120 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "odh_eng_ci_cycle_duration_p50_minutes{period=\"$period\"}",
          "legendFormat": "p50",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true
        },
        {
          "expr": "odh_eng_ci_cycle_duration_p90_minutes{period=\"$period\"}",
          "legendFormat": "p90",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true
        }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "title": "Totals",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "odh_eng_ci_total_prs_with_ci{period=\"$period\"}",
          "legendFormat": "PRs with CI data",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true
        },
        {
          "expr": "odh_eng_ci_total_cycles{period=\"$period\"}",
          "legendFormat": "Test cycles",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true
        },
        {
          "expr": "odh_eng_ci_total_job_runs{period=\"$period\"}",
          "legendFormat": "Job runs",
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true
        }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "title": "CI Hours per PR (p50 / p90)",
      "description": "Total wall-clock hours a PR spent waiting for CI across all test cycles.\n\nThis is the developer's CI wait budget per PR. Combine with retest tax to identify whether the cost comes from slow cycles or many retries.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "odh_eng_ci_hours_per_pr_p50{period=\"$period\"}",
          "legendFormat": "p50",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true
        },
        {
          "expr": "odh_eng_ci_hours_per_pr_p90{period=\"$period\"}",
          "legendFormat": "p90",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true
        }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "title": "Monthly CI Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "collapsed": false
    },
    {
      "title": "Monthly Cycles & Failures",
      "description": "Total test cycles and cycle failure count per month. Stacked bars show the proportion of failures.",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failures" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Cycles" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          }
        ]
      },
      "options": {
        "xField": "month",
        "stacking": "none",
        "barWidth": 0.7,
        "showValue": "never"
      },
      "targets": [
        {
          "expr": "odh_eng_ci_monthly_cycles",
          "legendFormat": "Cycles",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true,
          "format": "table"
        },
        {
          "expr": "odh_eng_ci_monthly_failures",
          "legendFormat": "Failures",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "month", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": { "Value #A": "Cycles", "Value #B": "Failures" }
          }
        },
        {
          "id": "sortBy",
          "options": { "sort": [{ "field": "month" }] }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "title": "Monthly Failure Rate & Retest Tax",
      "description": "Cycle failure rate (%) and retest tax (cycles per PR) trend over time.\n\nImproving CI health shows as declining failure rate and retest tax converging toward 1.0.",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failure %" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Retest Tax" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          }
        ]
      },
      "options": {
        "xField": "month",
        "stacking": "none",
        "barWidth": 0.7,
        "showValue": "never"
      },
      "targets": [
        {
          "expr": "odh_eng_ci_monthly_failure_pct",
          "legendFormat": "Failure %",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true,
          "format": "table"
        },
        {
          "expr": "odh_eng_ci_monthly_retest_tax",
          "legendFormat": "Retest Tax",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "month", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": { "Value #A": "Failure %", "Value #B": "Retest Tax" }
          }
        },
        {
          "id": "sortBy",
          "options": { "sort": [{ "field": "month" }] }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "title": "Failure Rate Trends (%)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "collapsed": false
    },
    {
      "title": "Monthly Cycle Failure Rate (%)",
      "description": "Percentage of test cycles that failed each month.\n\nShows the long-term trend of CI reliability. A declining line means CI is becoming more stable.\n\nMonths with fewer than 10 cycles are excluded.",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "max": 100,
          "min": 0,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "vertical",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color",
        "minVizWidth": 8,
        "minVizHeight": 16,
        "namePlacement": "auto"
      },
      "targets": [
        {
          "expr": "odh_eng_ci_monthly_failure_pct and odh_eng_ci_monthly_cycles >= 10",
          "legendFormat": "{{month}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true
        }
      ],
      "transformations": [],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "title": "Weekly Cycle Failure Rate (%)",
      "description": "Percentage of test cycles that failed each week.\n\nShows the short-term trend of CI reliability. Useful for spotting regressions or improvements week over week.\n\nWeeks with fewer than 10 cycles are excluded.",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "max": 100,
          "min": 0,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "vertical",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color",
        "minVizWidth": 8,
        "minVizHeight": 16,
        "namePlacement": "auto"
      },
      "targets": [
        {
          "expr": "odh_eng_ci_weekly_failure_pct and odh_eng_ci_weekly_cycles >= 10",
          "legendFormat": "{{week}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "instant": true
        }
      ],
      "transformations": [],
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
    },
    {
      "title": "Failure Trends",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "collapsed": false
    },
    {
      "title": "Weekly Cycle Failures Over Time",
      "description": "Total test cycles and failures per week. Shows whether CI health is trending up or down.\n\nA declining failure count with stable total cycles indicates improving CI reliability.",
      "type": "barchart",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 37 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
