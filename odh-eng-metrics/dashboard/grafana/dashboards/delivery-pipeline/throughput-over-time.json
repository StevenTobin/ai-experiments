  "panels": [
    {
      "title": "PRs Merged per Month",
      "description": "Number of pull requests merged to upstream main each month. Shows the team delivery throughput trend. Higher bars mean more changes shipped.",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 30
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "odh_eng_monthly_prs_merged",
          "legendFormat": "{{month}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "instant": true
        }
      ]
    },
    {
      "title": "Releases per Month",
      "description": "Monthly release output broken down by type.\n\n- **Stable**: Production-quality v*.*.0 releases\n- **EA**: Early Access pre-releases (v*.*.*-ea.*)\n- **Patch**: Hotfix releases (v*.*.1+) indicating a prior release had issues",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "collapsed": false
    },
